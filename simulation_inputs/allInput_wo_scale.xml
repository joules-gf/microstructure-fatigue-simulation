<input>
    
    <domain>
        <shape> square </shape>
        <side_length> 1 </side_length>
    </domain>

    <material>
        <name> Phase-0 </name>
        <shape> circle </shape>
        <fraction> 0.1 </fraction>
        <size>
            <dist_type> uniform </dist_type>
            <loc> 0.05 </loc>
        </size>
        <plastic_stress> 350 </plastic_stress>
    </material>
    
    <material>
        <name> Phase-1 </name>
        <shape> circle </shape>
        <fraction> 0.1 </fraction>
        <size>
            <dist_type> uniform </dist_type>
            <loc> 0.05 </loc>
        </size>
        <plastic_stress> 470 </plastic_stress>
    </material>

    <material>
        <name> Phase-2 </name>
        <shape> circle </shape>
        <fraction> 0.4 </fraction>
        <size>
            <dist_type> uniform </dist_type>
            <loc> 0.05 </loc>
        </size>
        <plastic_stress> 891 </plastic_stress>
    </material>
    
    <material>
        <name> Phase-3 </name>
        <shape> circle </shape>
        <fraction> 0.4 </fraction>
        <size>
            <dist_type> uniform </dist_type>
            <loc> 0.05 </loc>
        </size>
        <plastic_stress> 891 </plastic_stress>
    </material>

    <settings>
        <verbose> True </verbose>
        <restart> True </restart>

        <mesh_min_angle> 25 </mesh_min_angle>
        <mesh_max_edge_length> 0.00175 </mesh_max_edge_length>

        <rng_seeds>
            <size> 1000 </size>
        </rng_seeds>

        <filetypes>
            <seeds_plot> png </seeds_plot>
            <poly_plot> png </poly_plot>
            <tri> abaqus </tri>
            <tri_plot> png </tri_plot>
            <verify_plot> pdf </verify_plot>
        </filetypes>
    </settings>

    <abaqus>
        <E> 71000 </E>
        <nu> 0.33 </nu>
        <displacement_yy> 0.01 </displacement_yy>

        <cyclic_parameters>
            <rRatio_strain> 0.4 </rRatio_strain>
            <frequency_hz> 5 </frequency_hz>
            <start_min> True </start_min>
            <time_increment_s> 0.01 </time_increment_s>
        </cyclic_parameters>

        <num_increments_step> 125 </num_increments_step>
    </abaqus>

</input>